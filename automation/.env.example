# Pipeline Guardian — todas as variáveis são OPCIONAIS.
# Sem OPENAI_API_KEY e OPENAI_MODEL, o agente usa o classificador
# determinístico e ainda produz um diagnóstico válido (usedFallback: true).

# --- Modelo (opcional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_MS=45000

# --- Contexto do pipeline (opcional; preenchido pelo CI quando existir) ---
# GITHUB_REPOSITORY=senai/copa-figurinhas
# GITHUB_REF_NAME=feat/minha-branch
# GITHUB_SHA=
# GITHUB_EVENT_NAME=pull_request
# GITHUB_RUN_ID=
# PR_NUMBER=42

# Ambiente alvo: staging | production. Qualquer outro valor exige aprovação humana.
DEPLOY_ENVIRONMENT=staging
# Rollback de production sempre exige aprovação humana.
DEPLOY_ROLLBACK=false

# Comandos do pipeline analisados no modo real (separados por vírgula).
# AGENT_PIPELINE_COMMANDS=npm run lint,npm run test,npm run build

# Base do diff analisado (padrão: HEAD, ou seja, o working tree).
# AGENT_DIFF_BASE=origin/main

# --- Comentário na Pull Request ---
# Publicar exige opt-in explícito. Sem isto, o agente só grava
# reports/pr-comment.md e NÃO chama a API do GitHub.
AUTOMATION_ALLOW_PR_COMMENT=false
# GITHUB_TOKEN=
