# Configuração do ChatOps. Copie para `chatops/.env` e preencha.
# `chatops/.env` NÃO é versionado (a raiz já ignora `.env`).

# Segredo compartilhado do HMAC. O mesmo valor precisa estar no secret
# CHATOPS_SHARED_SECRET do GitHub Actions — é ele que faz as duas pontas
# chegarem à mesma assinatura.
#   openssl rand -hex 32
CHATOPS_SHARED_SECRET=troque-por-um-valor-aleatorio-de-32-bytes

# Bearer token da API. Também precisa existir como secret no GitHub Actions.
#   openssl rand -hex 32
CHATOPS_API_TOKEN=troque-por-outro-valor-aleatorio

# URLs dos incoming webhooks do Discord.
# Um webhook do Discord é um segredo em formato de URL: quem tem a URL publica
# no canal. Elas vivem SÓ aqui — o payload nunca carrega uma URL de webhook.
# Discord → Editar canal → Integrações → Webhooks → Novo webhook → Copiar URL.
DISCORD_WEBHOOK_URL_TEST=https://discord.com/api/webhooks/000000000000000000/xxxxxxxxxxxxxxxxxxxxxxxx
DISCORD_WEBHOOK_URL_CLASS=https://discord.com/api/webhooks/000000000000000000/yyyyyyyyyyyyyyyyyyyyyyyy

# Allowlist: o único repositório de onde eventos são aceitos.
ALLOWED_REPOSITORY=senai/copa-figurinhas

# Janela de aceitação do timestamp, em segundos. Fora dela, o evento é rejeitado
# (defesa contra replay de um evento capturado).
MAX_TIMESTAMP_SKEW_SECONDS=300

# Cliente HTTP do Discord.
DISCORD_TIMEOUT_SECONDS=10
DISCORD_MAX_ATTEMPTS=3
